      "decoder_heads": 8,
      "decoder_d_ff": 256
    }
  },
  "metrics": {
    "primary": ["mse", "mae"],
    "diagnostics": [
      "metrics_by_horizon",
      "metrics_by_segment",
      "segment_query_similarity",
      "parameter_count"
    ]
  },
  "remote": {
    "host": "529_Lab-3090",
    "conda_env": "moe",
    "runner": "scripts/remote/run_phase1_segment_decoder_gate.sh",
    "gpu_policy": "check nvidia-smi before every run; prefer GPU 1 or 2 when memory is safe; GPU_IDS may contain one or two selected GPUs"
  }
}
